<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application

        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Foliadeiros"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".UI.Favoritas"
            android:exported="false" />
        <activity
            android:name=".UI.InfoFoliada"
            android:exported="false" />
        <activity
            android:name=".UI.listadoFoliadas"
            android:exported="false" />
        <activity
            android:name=".UI.Provincias"
            android:exported="false" />
        <activity
            android:name=".UI.Rexistro"
            android:exported="true" />
        <activity
            android:name=".UI.LogIn"
            android:exported="true" />
        <activity
            android:name=".UI.Inicio"
            android:exported="true" />
        <activity
            android:name=".UI.MainActivity"
            android:exported="false" />
        <activity
            android:name=".UI.DetalleFoliadaActivity"
            android:exported="false" />
        <activity
            android:name=".UI.CrearEditarFoliadaActivity"
            android:exported="false" />
        <activity
            android:name=".UI.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>