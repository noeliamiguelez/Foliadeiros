<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1D1"
    tools:context=".UI.LogIn">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#A30000">
        <ImageButton
            android:id="@+id/bt_atras"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/arrow_back"
            android:scaleType="centerInside"

            android:background="@android:color/transparent"/>
        <TextView
            android:id="@+id/titulo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="0dp"
            android:text="Foliada de Melide"
            android:gravity="center"
            android:textSize="30dp"
            android:textColor="@color/white"
            android:fontFamily="@font/jeju_hallasan"/>
    </androidx.appcompat.widget.Toolbar>

    <ImageView
        android:id="@+id/cartel"
        android:layout_width="300dp"
        android:layout_height="250dp"
        android:adjustViewBounds="true"
        android:layout_below="@+id/toolbar"
        android:layout_marginTop="20dp"
        android:layout_centerHorizontal="true"
        />
    <ImageButton
        android:id="@+id/bt_favorita"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_below="@+id/cartel"
        android:layout_marginTop="10dp"
        android:layout_centerHorizontal="true"/>

    <ImageButton
        android:id="@+id/bt_no_favorita"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_below="@+id/bt_favorita"
        android:layout_marginTop="10dp"
        android:layout_centerHorizontal="true"/>

    <TextView
        android:id="@+id/txt_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/bt_no_favorita"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"
        android:text="Data: "/>
    <TextView
        android:id="@+id/fecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/bt_no_favorita"
        android:layout_toRightOf="@+id/txt_data"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"/>

    <TextView
        android:id="@+id/txt_hora"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_data"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"
        android:text="Hora: "/>
    <TextView
        android:id="@+id/hora"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/fecha"
        android:layout_toRightOf="@+id/txt_hora"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"/>

    <TextView
        android:id="@+id/txt_grupos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt_hora"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"
        android:text="Grupos: "/>
    <TextView
        android:id="@+id/grupos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/hora"
        android:layout_toRightOf="@+id/txt_grupos"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"/>

    <TextView
        android:id="@+id/txt_descripcion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/grupos"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"
        android:text="Descripción: "/>
    <TextView
        android:id="@+id/descripcion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/grupos"
        android:layout_toRightOf="@+id/txt_descripcion"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"/>

    <TextView
        android:id="@+id/txt_ubicacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/descripcion"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"
        android:text="Ubicación: "/>
    <TextView
        android:id="@+id/ubicacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/descripcion"
        android:layout_toRightOf="@+id/txt_ubicacion"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="15dp"
        android:fontFamily="@font/jeju_hallasan"/>
    <ImageButton
        android:id="@+id/maps"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="3dp"
        android:layout_marginLeft="15dp"
        android:layout_below="@+id/ubicacion"
        android:src="@drawable/map_location_dot_solid"
        android:scaleType="centerInside"
        android:background="@android:color/transparent"
        />

</RelativeLayout>